{
    "interface_version": 2,
    "name": "MaaRoco",
    "description": "$project.description",
    "contact": "$project.contact",
    "license": "MIT",
    "github": "https://github.com/Tortes/MaaRoco",
    "version": "0.1.0",
    "languages": {
        "zh_cn": "locales/interface/zh_cn.json",
        "en_us": "locales/interface/en_us.json"
    },
    "controller": [
        {
            "name": "Win32-Front",
            "label": "$controller.Win32-Front.label",
            "description": "$controller.Win32-Front.description",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": ".*",
                "screencap": "ScreenDC",
                "mouse": "Seize",
                "keyboard": "PostMessage"
            },
            "permission_required": true
        },
        {
            "name": "Win32-Window-Background",
            "label": "$controller.Win32-Window-Background.label",
            "description": "$controller.Win32-Window-Background.description",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": ".*",
                "screencap": "PrintWindow",
                "mouse": "SendMessageWithWindowPos",
                "keyboard": "PostMessage"
            },
            "permission_required": true
        },
        {
            "name": "Win32-Interception",
            "label": "$controller.Win32-Interception.label",
            "description": "$controller.Win32-Interception.description",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": ".*",
                "screencap": "ScreenDC",
                "mouse": "Interception",
                "keyboard": "PostMessage"
            },
            "permission_required": true
        }
    ],
    "resource": [
        {
            "name": "default",
            "label": "$resource.default.label",
            "path": [
                "./resource"
            ]
        }
    ],
    "group": [
        {
            "name": "assist",
            "label": "$group.assist.label",
            "default_expand": true
        }
    ],
    "task": [],
    "import": [
        "tasks/ContinuousThrow.json"
    ]
}
